---
interface Props {
  header?: string;
  removeGap?: boolean;
  class?: string;
  id?: string;
}

const { header, removeGap = false, class: className = '', id } = Astro.props;
---

<div
  id={id}
  class={`group flex h-full w-full flex-col rounded border border-slate-400 p-6 ${removeGap ? '' : 'gap-4'} ${className}`}
>
  {
    header && (
      <h3 class="text-center text-sm text-slate-600 md:text-left">{header}</h3>
    )
  }
  <slot />
</div>
