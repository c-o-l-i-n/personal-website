---
interface Props {
  header?: string;
  removeGap?: boolean;
  class?: string;
  id?: string;
}

const { header, removeGap = false, class: className = '', id } = Astro.props;
---

<div id={id} class={`group window flex h-full w-full flex-col ${className}`}>
  <div class="title-bar">
    <div class="title-bar-text">{header ?? 'Colin Williams'}</div>
    <div class="title-bar-controls">
      <button aria-label="Minimize" tabindex="-1" aria-hidden="true"></button>
      <button aria-label="Maximize" tabindex="-1" aria-hidden="true"></button>
      <button aria-label="Close" data-window-close></button>
    </div>
  </div>
  <div class={`window-body flex flex-1 flex-col ${removeGap ? '' : 'gap-4'}`}>
    <slot />
  </div>
</div>
