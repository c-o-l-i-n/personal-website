---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
---

<BaseLayout title="404 — Not Found">
  <Card class="bg-white">
    <div class="flex flex-col items-center gap-6 py-8 text-center">
      <p class="font-mono text-8xl font-extrabold text-slate-300">404</p>
      <p class="text-slate-600">This page doesn't exist or may have moved.</p>
    </div>
  </Card>
</BaseLayout>
