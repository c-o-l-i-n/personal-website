---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Not Found">
  <div class="flex flex-1 items-center justify-center py-12">
    <div class="window" style="width: 420px; max-width: 100%;">
      <div class="title-bar">
        <div class="title-bar-text">Colin.exe - Program Error</div>
        <div class="title-bar-controls">
          <button aria-label="Close" data-window-close></button>
        </div>
      </div>
      <div class="window-body">
        <h1 class="sr-only">404 — Page Not Found</h1>
        <div class="flex items-start gap-4 p-2">
          <img src="/images/xp-error-icon.svg" width="32" height="32" alt="" />
          <p>
            This page has performed an illegal operation and will be closed.
            If the problem persists, contact the system vendor.<br /><br />
            <strong>Error: 0x00000404 — PAGE_NOT_FOUND</strong>
          </p>
        </div>
        <section class="status-bar mt-2">
          <p class="status-bar-field">
            The page you requested doesn't exist or may have moved.
          </p>
        </section>
        <div class="mt-4 flex justify-end">
          <a href="/" class="win-button" style="min-width: 88px;">OK</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
