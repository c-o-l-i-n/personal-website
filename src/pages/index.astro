---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.published);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime(),
);
const featuredPost = sortedPosts.find((p) => p.data.featured);
const latestPost = sortedPosts[0];

const yearsOfExperience = Math.round(
  (Date.now() - new Date('2020-08-01').getTime()) / 31557600000,
);

const skillPills = [
  { iconSrc: '/images/logos/angular.svg', text: 'Angular Architect' },
  { iconSrc: '/images/logos/ts.svg', iconSize: 14, text: 'TypeScript Titan' },
  {
    iconSrc: '/images/logos/supabase.svg',
    iconSize: 14,
    text: 'Supabase Sage',
  },
  { iconSrc: '/images/logos/firebase.svg', text: 'Firebase Fan' },
  { iconSrc: '/images/logos/openai.svg', text: 'AI Artisan' },
];

const workExperienceRows = [
  {
    jobTitle: 'Lead Frontend Engineer & Architect',
    company: 'Ecosystems.io',
    companyUrl: 'https://ecosystems.io',
    logoSrc: '/images/logos/eco.svg',
    dateRange: 'Jan 2026 - Present',
  },
  {
    jobTitle: 'Senior Frontend Engineer & Architect',
    company: 'Ecosystems.io',
    companyUrl: 'https://ecosystems.io',
    logoSrc: '/images/logos/eco.svg',
    dateRange: 'Feb 2024 - Jan 2026',
  },
  {
    jobTitle: 'Software Engineer II',
    company: 'Ecosystems.io',
    companyUrl: 'https://ecosystems.io',
    logoSrc: '/images/logos/eco.svg',
    dateRange: 'Mar 2022 - Feb 2024',
  },
  {
    jobTitle: 'Software Engineer I',
    company: 'JPMorgan Chase & Co.',
    companyUrl: 'https://jpmorganchase.com',
    logoSrc: '/images/logos/chase.svg',
    dateRange: 'Jul 2021 - Mar 2022',
  },
  {
    jobTitle: 'Software Engineer Intern',
    company: 'JPMorgan Chase & Co.',
    companyUrl: 'https://jpmorganchase.com',
    logoSrc: '/images/logos/chase.svg',
    dateRange: 'Jun 2020 - Aug 2020',
  },
  {
    jobTitle: 'Software Engineer Intern',
    company: 'Hyland Software',
    companyUrl: 'https://hyland.com',
    logoSrc: '/images/logos/hyland.svg',
    dateRange: 'May 2019 - Aug 2019',
  },
  {
    jobTitle: 'Software Engineer Intern',
    company: 'Diebold Nixdorf',
    companyUrl: 'https://dieboldnixdorf.com',
    logoSrc: '/images/logos/dn.svg',
    dateRange: 'May 2018 - Aug 2018',
  },
];

const leadershipRows = [
  {
    jobTitle: 'Conference Speaker',
    company: 'ng-conf "Lightning Talks"',
    companyUrl: 'https://youtu.be/tlWlFpEmTeE',
    logoSrc: '/images/logos/ng-conf.webp',
    dateRange: 'Mar 2024',
  },
  {
    jobTitle: 'Angular Development Mentor',
    company: 'Ecosystems.io',
    companyUrl: 'https://ecosystems.io',
    logoSrc: '/images/logos/eco.svg',
    dateRange: 'Jun 2023 - Present',
  },
  {
    jobTitle: 'Programming Teacher & Tutor',
    company: 'Coding with Colin',
    companyUrl: 'https://codingwithcolin.com',
    logoSrc: '/images/logos/grad.svg',
    dateRange: 'Jun 2020 - Nov 2021',
  },
  {
    jobTitle: 'Squad Leader',
    company: 'The OSU Marching Band',
    companyUrl: 'https://tbdbitl.osu.edu/',
    logoSrc: '/images/logos/osu.svg',
    dateRange: 'Jun 2020 - Dec 2021',
  },
];

const sideProjectRows = [
  {
    name: 'Mell',
    url: 'https://github.com/VoxelPenguin/mell#readme',
    logoSrc: '/images/logos/mell.webp',
    notes:
      "Empower your community to report and solve local issues! Winner of Harper Hack '25",
  },
  {
    name: 'Whisker Jam',
    url: 'https://github.com/c-o-l-i-n/whisker-jam#readme',
    logoSrc: '/images/logos/whisker-jam.webp',
    notes:
      'Create a realtime virtual rock band made up of cats! Winner of the Supabase Launch Week 12 Hackathon',
  },
  {
    name: 'EventMaster Pro',
    url: 'https://github.com/joshies-foundation/event-master-pro#readme',
    logoSrc: '/images/logos/emp.svg',
    notes:
      'Supercharge dynamic, multi-day competitions with realtime brackets, betting, analytics, and more',
  },
  {
    name: 'Potluk',
    url: 'https://potl.uk',
    logoSrc: '/images/logos/potluk.svg',
    notes: 'Coordinate who brings what to your potluck',
  },
  {
    name: 'Presto Parts',
    url: 'https://prestoparts.org',
    logoSrc: '/images/logos/pp.svg',
    notes: 'Organize sheet music PDFs in a few minutes, not many hours',
  },
  {
    name: 'Drill Generator',
    url: 'https://drillgenerator.com',
    logoSrc: '/images/logos/drill-generator.svg',
    notes: 'Generate drills in the style of OSUMB tryouts',
  },
];
---

<BaseLayout title="Colin Williams - Software Engineer & Frontend Architect">
  <div class="flex flex-col gap-5">
    <!-- About Me -->
    <Card header="About Me">
      <h3
        class="flex flex-col justify-center text-center font-mono text-xl font-medium sm:flex-row md:justify-start md:text-left md:text-2xl"
      >
        <span class="sm:mr-3 md:mr-4">
          <span class="text-slate-400 dark:text-slate-500">&lcub;&lcub;</span
          >Software Engineer<span class="text-slate-400 dark:text-slate-500"
            >&rcub;&rcub;</span
          >
        </span>
        <span class="whitespace-nowrap">&amp; Frontend Architect</span>
      </h3>

      <div class="flex flex-wrap gap-1">
        {
          skillPills.map(({ iconSrc, iconSize, text }) => (
            <a href="#experience">
              <span class="flex shrink-0 items-center gap-1 rounded border border-slate-200 bg-white px-2 py-1 text-sm dark:border-slate-700 dark:bg-slate-900">
                <img
                  src={iconSrc}
                  alt=""
                  width={iconSize ?? 16}
                  height={iconSize ?? 16}
                  class="h-4"
                />
                {text}
              </span>
            </a>
          ))
        }
      </div>

      <p>
        As a software engineer, I'm passionate about crafting exceptional user
        experiences. Architecting robust Angular applications is where I truly
        shine.
      </p>

      <p>As a person, I'm passionate about music, cats, skiing, and cashews.</p>
    </Card>

    <!-- Featured & Latest Articles -->
    <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
      <BlogPostCard
        post={featuredPost ?? latestPost}
        header="Featured Article"
      />
      <BlogPostCard post={latestPost} header="Latest Article" />
    </div>

    <!-- Experience -->
    <Card id="experience" class="bg-white dark:bg-slate-900">
      <h2
        class="mb-4 text-center font-mono text-xl font-medium md:text-left md:text-2xl"
      >
        Experience ({yearsOfExperience} yrs)
      </h2>
      <div>
        {
          workExperienceRows.map(
            ({ jobTitle, company, companyUrl, logoSrc, dateRange }, i) => (
              <div
                class={`border-slate-200 py-4 md:border-b dark:border-slate-700 ${i === workExperienceRows.length - 1 ? 'border-none' : ''} ${i === 0 ? 'pt-0' : ''}`}
              >
                <div class="flex flex-col items-center justify-between gap-1 md:flex-row">
                  <div class="flex w-full flex-row items-center gap-3 md:w-auto md:gap-2">
                    <a
                      href={companyUrl}
                      target="_blank"
                      aria-label={`Go to ${company} website`}
                      class="shrink-0"
                    >
                      <img
                        src={logoSrc}
                        alt=""
                        height="32"
                        width="32"
                        class="size-12 rounded-lg md:size-8 md:rounded-md"
                      />
                    </a>
                    <p class="flex flex-col md:mt-0 md:flex-row md:gap-1.5">
                      <span class="font-medium">{jobTitle}</span>
                      <span>
                        &commat;
                        <a
                          href={companyUrl}
                          target="_blank"
                          class="-mt-0.5 whitespace-nowrap hover:underline md:m-0"
                          aria-label={`Go to ${company} website`}
                        >
                          {company}
                        </a>
                      </span>
                      <span class="mt-1 inline text-sm text-slate-400 md:hidden md:text-base">
                        {dateRange}
                      </span>
                    </p>
                  </div>
                  <p class="hidden shrink text-sm text-slate-500 md:inline md:text-base">
                    {dateRange}
                  </p>
                </div>
              </div>
            ),
          )
        }
      </div>
    </Card>

    <!-- Leadership & Mentoring -->
    <Card id="leadership" class="bg-white dark:bg-slate-900">
      <h2
        class="mb-4 text-center font-mono text-xl font-medium md:text-left md:text-2xl"
      >
        Leadership & Mentoring
      </h2>
      <div>
        {
          leadershipRows.map(
            ({ jobTitle, company, companyUrl, logoSrc, dateRange }, i) => (
              <div
                class={`border-slate-200 py-4 md:border-b dark:border-slate-700 ${i === leadershipRows.length - 1 ? 'border-none' : ''} ${i === 0 ? 'pt-0' : ''}`}
              >
                <div class="flex flex-col items-center justify-between gap-1 md:flex-row">
                  <div class="flex w-full flex-row items-center gap-3 md:w-auto md:gap-2">
                    <a
                      href={companyUrl}
                      target="_blank"
                      aria-label={`Go to ${company} website`}
                      class="shrink-0"
                    >
                      <img
                        src={logoSrc}
                        alt=""
                        height="32"
                        width="32"
                        class="size-12 rounded-lg md:size-8 md:rounded-md"
                      />
                    </a>
                    <p class="flex flex-col md:mt-0 md:flex-row md:gap-1.5">
                      <span class="font-medium">{jobTitle}</span>
                      <span>
                        &commat;
                        <a
                          href={companyUrl}
                          target="_blank"
                          class="-mt-0.5 whitespace-nowrap hover:underline md:m-0"
                          aria-label={`Go to ${company} website`}
                        >
                          {company}
                        </a>
                      </span>
                      <span class="mt-1 inline text-sm text-slate-400 md:hidden md:text-base">
                        {dateRange}
                      </span>
                    </p>
                  </div>
                  <p class="hidden shrink text-sm text-slate-500 md:inline md:text-base">
                    {dateRange}
                  </p>
                </div>
              </div>
            ),
          )
        }
      </div>
    </Card>

    <!-- Side Projects -->
    <Card id="projects" class="bg-white dark:bg-slate-900">
      <h2
        class="mb-4 text-center font-mono text-xl font-medium md:text-left md:text-2xl"
      >
        Side Projects
      </h2>
      <div>
        {
          sideProjectRows.map(({ name, url, logoSrc, notes }, i) => (
            <div
              class={`border-slate-200 py-4 md:border-b dark:border-slate-700 ${i === sideProjectRows.length - 1 ? 'border-none' : ''} ${i === 0 ? 'pt-0' : ''}`}
              style="text-wrap: balance"
            >
              <div class="flex flex-col items-center justify-end gap-1 md:flex-row">
                <div class="flex w-full flex-row items-center gap-3 md:w-auto md:gap-2">
                  <a
                    href={url}
                    target="_blank"
                    aria-label={`Go to ${name} website`}
                    class="shrink-0"
                  >
                    <img
                      src={logoSrc}
                      alt=""
                      height="32"
                      width="32"
                      class="size-12 rounded-lg md:size-8 md:rounded-md"
                    />
                  </a>
                  <p class="flex flex-col md:mt-0 md:flex-row md:gap-1.5">
                    <a
                      href={url}
                      target="_blank"
                      class="-mt-0.5 font-medium whitespace-nowrap hover:underline md:m-0"
                      aria-label={`Go to ${name} website`}
                    >
                      {name}
                    </a>
                    <span class="text-sm text-slate-400 md:hidden md:text-base">
                      {notes}
                    </span>
                  </p>
                </div>
                <p class="hidden grow text-sm text-slate-500 md:block md:text-right md:text-base">
                  {notes}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </Card>
  </div>
</BaseLayout>
