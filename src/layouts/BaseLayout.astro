---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DesktopIcons from '../components/DesktopIcons.astro';
import { socialIcons } from '../lib/social-icons';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description = "As a software engineer, I'm passionate about crafting exceptional user experiences. Architecting robust Angular applications is where I truly shine.",
  ogImage = '/images/colin-banner.webp',
  ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site ?? Astro.url.origin,
);

const trayIconClass = 'h-4 w-auto align-[-0.125rem] overflow-visible';
const trayLinks = socialIcons.map(({ href, label, icon }) => ({
  href,
  label,
  icon: icon(trayIconClass),
}));

const pathname = Astro.url.pathname;
const taskbarApps = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
].map((app) => ({
  ...app,
  focused:
    app.href === '/' ? pathname === '/' : pathname.startsWith(app.href),
}));
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/webp" href="/images/colin.webp?cb=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Colin Williams" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@n0t_buddy" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class="min-h-screen pb-11">
    <div
      class="fixed inset-0 -z-10 bg-[url('/images/bliss.webp')] bg-cover bg-center bg-no-repeat"
      aria-hidden="true"
    >
    </div>

    <DesktopIcons />

    <div class="mx-auto flex max-w-3xl flex-col gap-5 px-4 py-8">
      <Header />
      <main class="flex flex-col gap-5">
        <slot />
      </main>
      <Footer />
    </div>

    <footer
      class="taskbar fixed inset-x-0 bottom-0 z-50 flex h-8 items-center justify-between px-1"
    >
      <div class="flex h-full items-center gap-1.5" aria-hidden="true">
        <button type="button" class="start-button" tabindex="-1">
          <svg
            width="17"
            height="17"
            viewBox="0 0 22 22"
            xmlns="http://www.w3.org/2000/svg"
          >
            <defs>
              <linearGradient id="flagRed" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#fdbb59"></stop>
                <stop offset="100%" stop-color="#e2431b"></stop>
              </linearGradient>
              <linearGradient id="flagGreen" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#a4e05a"></stop>
                <stop offset="100%" stop-color="#3f8f1c"></stop>
              </linearGradient>
              <linearGradient id="flagBlue" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#8fb4fd"></stop>
                <stop offset="100%" stop-color="#2b52e0"></stop>
              </linearGradient>
              <linearGradient id="flagGold" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#f5d54c"></stop>
                <stop offset="100%" stop-color="#c99a12"></stop>
              </linearGradient>
            </defs>
            <g transform="rotate(-8 11 11)">
              <rect x="1" y="1" width="9" height="9" rx="1.5" fill="url(#flagRed)"
              ></rect>
              <rect
                x="12"
                y="1"
                width="9"
                height="9"
                rx="1.5"
                fill="url(#flagGreen)"></rect>
              <rect
                x="1"
                y="12"
                width="9"
                height="9"
                rx="1.5"
                fill="url(#flagBlue)"></rect>
              <rect
                x="12"
                y="12"
                width="9"
                height="9"
                rx="1.5"
                fill="url(#flagGold)"></rect>
            </g>
          </svg>
          <span>start</span>
        </button>
        <div class="taskbar-divider hidden sm:block"></div>
        {
          taskbarApps.map(({ label, focused }) => (
            <button
              type="button"
              class={`taskbar-app-button hidden sm:inline-flex ${focused ? 'is-focused' : ''}`}
              tabindex="-1"
            >
              {label}
            </button>
          ))
        }
      </div>

      <div class="taskbar-tray flex h-full items-center gap-2 px-2 sm:gap-3 sm:px-3">
        {
          trayLinks.map(({ href, label, icon }) => (
            <a
              href={href}
              aria-label={label}
              target="_blank"
              rel="noopener noreferrer"
              class="hidden sm:inline-flex"
              set:html={icon}
            />
          ))
        }
        <span id="taskbar-clock" class="tabular-nums">--:--</span>
      </div>
    </footer>

    <script>
      const clockEl = document.getElementById('taskbar-clock');
      function tick() {
        if (!clockEl) return;
        clockEl.textContent = new Date().toLocaleTimeString([], {
          hour: 'numeric',
          minute: '2-digit',
        });
      }
      tick();
      setInterval(tick, 15_000);
    </script>
  </body>
</html>
