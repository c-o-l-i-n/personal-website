---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DesktopIcons from '../components/DesktopIcons.astro';
import { socialIcons } from '../lib/social-icons';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description = "As a software engineer, I'm passionate about crafting exceptional user experiences. Architecting robust Angular applications is where I truly shine.",
  ogImage = '/images/colin-banner.webp',
  ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site ?? Astro.url.origin,
);

const trayIconClass = 'h-4 w-auto align-[-0.125rem] overflow-visible';
const trayLinks = socialIcons.map(({ href, label, icon }) => ({
  href,
  label,
  icon: icon(trayIconClass),
}));

const pathname = Astro.url.pathname;
const taskbarApps = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
].map((app) => ({
  ...app,
  focused:
    app.href === '/' ? pathname === '/' : pathname.startsWith(app.href),
}));
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/webp" href="/images/colin.webp?cb=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Colin Williams" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@n0t_buddy" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class="min-h-screen pb-11">
    <div
      class="fixed inset-0 -z-10 bg-[url('/images/bliss.webp')] bg-cover bg-center bg-no-repeat"
      aria-hidden="true"
    >
    </div>

    <DesktopIcons />

    <div class="mx-auto flex max-w-3xl flex-col gap-5 px-4 py-8">
      <Header />
      <main class="flex flex-col gap-5">
        <slot />
      </main>
      <Footer />
    </div>

    <footer
      class="taskbar fixed inset-x-0 bottom-0 z-50 flex h-8 items-center justify-between px-1"
    >
      <div class="flex h-full items-center gap-1.5" aria-hidden="true">
        <button type="button" class="start-button" tabindex="-1">
          {/* Start button sprite from ShizukuIchi/winXP (MIT License), used as-is per license terms. */}
          <img
            src="/images/xp-start.png"
            alt=""
            width="106"
            height="34"
            draggable="false"
          />
        </button>
        <div class="taskbar-divider hidden sm:block"></div>
        {
          taskbarApps.map(({ label, focused }) => (
            <button
              type="button"
              class={`taskbar-app-button hidden sm:inline-flex ${focused ? 'is-focused' : ''}`}
              tabindex="-1"
            >
              {label}
            </button>
          ))
        }
      </div>

      <div class="taskbar-tray flex h-full items-center gap-2 px-2 sm:gap-3 sm:px-3">
        {
          trayLinks.map(({ href, label, icon }) => (
            <a
              href={href}
              aria-label={label}
              target="_blank"
              rel="noopener noreferrer"
              class="hidden sm:inline-flex"
              set:html={icon}
            />
          ))
        }
        <span id="taskbar-clock" class="tabular-nums">--:--</span>
      </div>
    </footer>

    <script>
      const clockEl = document.getElementById('taskbar-clock');
      function tick() {
        if (!clockEl) return;
        clockEl.textContent = new Date().toLocaleTimeString([], {
          hour: 'numeric',
          minute: '2-digit',
        });
      }
      tick();
      setInterval(tick, 15_000);
    </script>

    <script>
      // Drag any .window by its title bar, and dismiss it via the Close control.
      const DRAG_THRESHOLD = 4;

      let dragState: {
        el: HTMLElement;
        offsetX: number;
        offsetY: number;
        startX: number;
        startY: number;
      } | null = null;
      let topZ = 100;
      // True for one tick after a real drag (past the threshold) ends, so the
      // trailing `click` — e.g. on a card that's really an <a> — gets swallowed
      // instead of navigating away out from under the user.
      let suppressNextClick = false;

      function getPoint(e: MouseEvent | TouchEvent) {
        return 'touches' in e ? e.touches[0] : e;
      }

      function startDrag(e: MouseEvent | TouchEvent) {
        const target = e.target as HTMLElement;
        if (target.closest('.title-bar-controls')) return;
        const titleBar = target.closest('.title-bar');
        const winEl = titleBar?.closest<HTMLElement>('.window');
        if (!titleBar || !winEl) return;

        const rect = winEl.getBoundingClientRect();
        const point = getPoint(e);
        dragState = {
          el: winEl,
          offsetX: point.clientX - rect.left,
          offsetY: point.clientY - rect.top,
          startX: point.clientX,
          startY: point.clientY,
        };

        winEl.style.position = 'fixed';
        winEl.style.left = `${rect.left}px`;
        winEl.style.top = `${rect.top}px`;
        winEl.style.width = `${rect.width}px`;
        winEl.style.margin = '0';
        winEl.style.zIndex = String(++topZ);

        document.body.classList.add('is-dragging-window');
      }

      function onMove(e: MouseEvent | TouchEvent) {
        if (!dragState) return;
        if (e.cancelable) e.preventDefault();
        const point = getPoint(e);
        if (
          !suppressNextClick &&
          (Math.abs(point.clientX - dragState.startX) > DRAG_THRESHOLD ||
            Math.abs(point.clientY - dragState.startY) > DRAG_THRESHOLD)
        ) {
          suppressNextClick = true;
        }
        dragState.el.style.left = `${point.clientX - dragState.offsetX}px`;
        dragState.el.style.top = `${point.clientY - dragState.offsetY}px`;
      }

      function endDrag() {
        dragState = null;
        document.body.classList.remove('is-dragging-window');
      }

      document.addEventListener('mousedown', startDrag);
      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', endDrag);
      document.addEventListener('touchstart', startDrag, { passive: true });
      document.addEventListener('touchmove', onMove, { passive: false });
      document.addEventListener('touchend', endDrag);

      document.addEventListener(
        'click',
        (e) => {
          if (suppressNextClick) {
            e.preventDefault();
            e.stopPropagation();
            // Wait a tick before clearing so this same gesture's click (which
            // fires right after mouseup) is the one actually suppressed.
            setTimeout(() => {
              suppressNextClick = false;
            }, 0);
            return;
          }

          const closeBtn = (e.target as HTMLElement).closest(
            '[data-window-close]',
          );
          if (!closeBtn) return;
          closeBtn.closest('.window')?.remove();
        },
        true,
      );
    </script>
  </body>
</html>
